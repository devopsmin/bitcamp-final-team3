<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="project.tripMaker.dao.ScheduleDao">
    <resultMap id="CityResultMap" type="project.tripMaker.vo.City">
        <id column="city_no" property="cityNo"/>
        <result column="city_code" property="cityCode"/>
        <result column="city_name" property="cityName"/>
    </resultMap>

    <resultMap id="StateResultMap" type="project.tripMaker.vo.State">
        <id column="state_no" property="stateNo"/>
        <result column="city_no" property="cityNo"/>
        <result column="state_code" property="stateCode"/>
        <result column="state_name" property="stateName"/>
        <result column="state_photo" property="statePhoto"/>
    </resultMap>

    <resultMap id="LocationResultMap" type="project.tripMaker.vo.Location">
        <id column="location_no" property="locationNo"/>
        <result column="thirdclass_no" property="thirdclassNo"/>
        <result column="location_name" property="locationName"/>
        <result column="location_desc" property="locationDesc"/>
        <result column="location_photo" property="locationPhoto"/>
        <result column="location_tel" property="locationTel"/>
        <result column="location_addr" property="locationAddr"/>
        <result column="location_x" property="locationX"/>
        <result column="location_y" property="locationY"/>
        <result column="city_code" property="cityCode"/>
        <result column="state_code" property="stateCode"/>

    </resultMap>

    <select id="cityList" resultMap="CityResultMap">
        select
            city_no,
            city_code,
            city_name
        from
            city
    </select>

    <select id="stateList" resultMap="StateResultMap">
        SELECT
            s.state_no,
            s.state_code,
            s.state_name
        FROM
            state s
        right JOIN
            city c ON s.city_no = c.city_no
        where
            c.city_code=#{cityCode}
    </select>

    <select id="locationList" resultMap="LocationResultMap">
        SELECT
            l.location_no,
            l.thirdclass_no,
            l.location_name,
            l.location_desc,
            l.location_photo,
            l.location_tel,
            l.location_addr,
            l.location_x,
            l.location_y
        from
            location l
        right outer join
            state s on l.state_no = s.state_no
        where
            s.state_code=#{stateCode};
    </select>

    <select id="hotelList" resultMap="LocationResultMap">
        SELECT
            l.location_no,
            l.state_no,
            l.thirdclass_no,
            l.location_name,
            l.location_desc,
            l.location_photo,
            l.location_tel,
            l.location_addr,
            l.location_x,
            l.location_y
        from
            location l
                right outer join
            state s on l.state_no = s.state_no
        where
            s.state_name=#{stateName};
    </select>
</mapper>
